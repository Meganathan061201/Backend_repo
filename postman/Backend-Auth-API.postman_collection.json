    {
      "name": "File Uploads",
      "description": "Multer file uploads + Sharp image processing.\n\n**Postman setup:** Body → form-data → key must be `image` (single) or `images` (multiple) → type **File**.\n\nSee `FILE-UPLOAD-POSTMAN.md` for full guide.",
      "item": [
        {
          "name": "Upload Single Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": [],
                  "description": "Required field name: image. Allowed: JPEG, PNG, WebP. Max 5 MB."
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/upload/single",
              "host": ["{{baseUrl}}"],
